# Installed as /etc/quizpane/release-proxy.env with mode 0600.
# Do not commit the deployed file. Replace WEBHOOK_SECRET before enabling public
# GitHub webhooks. A public repository can read public Release metadata without
# GITHUB_TOKEN, but a fine-grained read-only token is recommended for stability.

GITHUB_OWNER=tianyoudoge
GITHUB_REPOSITORY=quizpane
GITHUB_TOKEN=
WEBHOOK_SECRET=replace-with-a-high-entropy-secret

LISTEN_HOST=127.0.0.1
LISTEN_PORT=8787
CACHE_DIR=/srv/quizpane/releases
STATE_DIR=/var/lib/quizpane
CACHE_MAX_BYTES=32212254720
KEEP_RELEASES=2
POLL_INTERVAL_SECONDS=1800
PREHEAT_ASSETS=QuizPane-macos-arm64.dmg,QuizPane-windows-x64.exe
LOG_LEVEL=info
